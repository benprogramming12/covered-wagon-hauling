# Copy this file to .env and fill in your values

# === DATABASE ===
DATABASE_URL="file:./dev.db"

# === NEXTAUTH ===
# Run: openssl rand -base64 32  (or any long random string)
NEXTAUTH_SECRET="replace-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# === ADMIN LOGIN ===
# Your admin email and password to log into the dashboard
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD="YourSecurePassword123"

# === STRIPE ===
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
# Get this from https://dashboard.stripe.com/webhooks after deploying
STRIPE_WEBHOOK_SECRET="whsec_..."

# === EMAIL NOTIFICATIONS (optional but recommended) ===
# Use Gmail: enable "App Passwords" in your Google account settings
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-gmail@gmail.com"
SMTP_PASS="your-app-password"
NOTIFY_EMAIL="your-gmail@gmail.com"
