generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Quote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Customer
  name  String
  email String
  phone String

  // Job details
  pickupAddress    String
  dropoffAddress   String
  scheduledDate    String
  scheduledTime    String
  cargoDescription String
  cargoSize        String
  notes             String?
  paymentPreference String  @default("deposit")
  paymentToken      String? @unique

  // Pricing & status
  // Status: pending | quoted | deposit_paid | in_progress | completed | cancelled
  status String @default("pending")
  price  Float?

  // Stripe
  stripeCustomerId       String?
  stripePaymentMethodId  String?
  depositPaymentIntentId String?
  balancePaymentIntentId String?
  depositPaid            Boolean @default(false)
  balancePaid            Boolean @default(false)
  depositAmount          Float?
  balanceAmount          Float?
}

model BlockedDate {
  id        String   @id @default(cuid())
  date      String   @unique
  reason    String?
  createdAt DateTime @default(now())
}

model RecurringBlock {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  label       String
  // Days of week: "0,1,2,3,4,5,6" (0=Sun, 6=Sat)
  daysOfWeek  String
  // Pattern: "weekly" | "biweekly" | "custom"
  pattern     String   @default("weekly")
  // For biweekly: which week does it start on (ISO date string)
  startDate   String
  // Optional end date
  endDate     String?
  active      Boolean  @default(true)
}
